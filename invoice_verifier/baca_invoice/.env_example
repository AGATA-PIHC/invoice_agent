# Google AI / Gemini API
# Set ke 0 untuk menggunakan Google AI Studio (API Key), 1 untuk Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=0

# API Key dari Google AI Studio (https://aistudio.google.com/app/apikey)
# Diperlukan jika GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=your_google_api_key_here

# SQLite database path untuk API PINTER upload/extract
# Default: data/invoice_verifier.db di project root
SQLITE_DB_PATH=data/invoice_verifier.db

# API key untuk endpoint /api/pinter/ (X-API-Key header)
# Jika tidak diset, auth dinonaktifkan (development only)
PINTER_API_KEY=your_pinter_api_key_here

# TTL trx_id dalam hari. Setelah ini, GET /api/pinter/extract return TRX_EXPIRED
PINTER_TRX_TTL_DAYS=7
