# ── Google AI ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here

# ── App ────────────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development

# ── Security ───────────────────────────────────────────────────────────────────
# Secret used to sign job tokens. Auto-generated if empty (tokens invalidated on restart).
JOB_SECRET_KEY=

# ── Upload ─────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=20
UPLOAD_DIR=tmp_uploads

# ── Concurrency ────────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=10
# Seconds before a completed job is evicted from memory
JOB_TTL_SECONDS=3600
